# Slack bot token with scopes: channels:history, channels:read (groups:history if private channel)
SLACK_BOT_TOKEN=

# Channel ID to scrape (e.g. C0123456789) for #partnerships
SLACK_CHANNEL_ID=

# Optional: Anthropic API key. If unset, LLM analysis is skipped and heuristics-only mode is used.
# To route through the Merge Gateway, set this to the gateway key and set ANTHROPIC_BASE_URL below.
ANTHROPIC_API_KEY=
# Optional: custom Anthropic-compatible endpoint. Leave blank for api.anthropic.com.
# Merge Gateway example: https://api-gateway.merge.dev/v1/anthropic
ANTHROPIC_BASE_URL=

# Optional: channel ID to post the rendered digest to via chat.postMessage (only used with --post)
SLACK_POST_CHANNEL_ID=

# Optional: Notion output (only used with --notion). See README "Notion output" section.
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_DATABASE_ID=
